	.pixelicons img.big {
		grid-column: span 2;
		grid-row: span 2;
	}
}
.pixelicons img:hover {
	transition: transform 100ms ease-out;
	transform: scale(1.5);
	image-rendering: crisp-edges;
	image-rendering: pixelated;
}
.pixelicons img:active {
